LOCALBRIDGE_PORT=3838
LOCALBRIDGE_DATA_DIR=$HOME/.chatgpt2localbridge
LOCALBRIDGE_LOG_DIR=$HOME/.chatgpt2localbridge/logs
LOCALBRIDGE_POLICY_PATH=/absolute/path/to/bridge.policy.json

# Required for hosted ChatGPT Custom Connector OAuth.
LOCALBRIDGE_OAUTH_ENABLED=1
LOCALBRIDGE_PUBLIC_BASE_URL=https://your-fixed-domain.example.com
LOCALBRIDGE_OAUTH_UNLOCK_CODE=replace-with-a-long-random-code
LOCALBRIDGE_DASHBOARD_TOKEN=replace-with-a-local-dashboard-token

# Optional compatibility/static auth. Prefer OAuth for ChatGPT connectors.
LOCALBRIDGE_AUTH_TOKEN=
LOCALBRIDGE_ALLOW_URL_TOKEN=0
LOCALBRIDGE_OAUTH_SCOPES=workspace:read workspace:write shell:exec

# Tool profile:
# - minimal / chatgpt-app: smallest ChatGPT connector surface; compatibility aliases only.
# - standard / normal: recommended default; project, policy, git, test, skill, trace, codex task tools.
# - full / debug: exposes low-level debug tools such as shell.exec and file patch/delete.
# - codex-runner-only: only Codex task/control-plane tools plus bridge/policy status.
LOCALBRIDGE_TOOL_PROFILE=standard

# Optional Codex Runner provider profile.
# official: use the normal Codex CLI login/config.
# openai-compatible: inject OPENAI_BASE_URL and an API key env into Codex Runner.
# sub2api: same API-compatible route, intended for a separately running sub2api gateway.
LOCALBRIDGE_CODEX_BIN=
LOCALBRIDGE_CODEX_PROVIDER=official
LOCALBRIDGE_CODEX_BASE_URL=
LOCALBRIDGE_CODEX_MODEL=
LOCALBRIDGE_CODEX_PROFILE=
LOCALBRIDGE_CODEX_HOME=
LOCALBRIDGE_CODEX_API_KEY_ENV=OPENAI_API_KEY
