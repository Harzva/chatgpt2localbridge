{
  "name": "chatgpt2localbridge",
  "version": "0.1.0",
  "description": "Codex/ChatGPT plugin app and OAuth-enabled MCP connector for approved local workspaces.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chatgpt2localbridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http 3838",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/test-mcp.sh",
    "tools:catalog": "npm run build >/dev/null && node scripts/export-mcp-tools.mjs",
    "docs:assets": "node scripts/render-doc-assets.mjs",
    "docs:preview": "python3 -m http.server 4178 --directory docs --bind 127.0.0.1",
    "rust:test": "cargo test --manifest-path rust/chatgpt2localbridge-rs/Cargo.toml",
    "rust:build": "cargo build --manifest-path rust/chatgpt2localbridge-rs/Cargo.toml",
    "rust:release": "cargo build --release --manifest-path rust/chatgpt2localbridge-rs/Cargo.toml",
    "macos:app": "bash scripts/build-macos-app.sh",
    "macos:install": "bash scripts/build-macos-app.sh --install",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "files": [
    "assets",
    "bridge.policy.example.json",
    ".env.example",
    "dist",
    "docs",
    "launchd",
    "macos",
    "rust/chatgpt2localbridge-rs/Cargo.lock",
    "rust/chatgpt2localbridge-rs/Cargo.toml",
    "rust/chatgpt2localbridge-rs/README.md",
    "rust/chatgpt2localbridge-rs/src",
    "scripts/build-macos-app.sh",
    "scripts/deploy-linux-bridge.sh",
    "scripts/export-mcp-tools.mjs",
    "scripts/install-launchd.sh",
    "scripts/render-doc-assets.mjs",
    "scripts/stop-launchd.sh",
    "scripts/test-mcp.sh",
    "src",
    "README.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "chatgpt",
    "codex",
    "plugin-app",
    "chatgpt-plugin-app",
    "codex-plugin-app",
    "connector",
    "oauth",
    "local-files",
    "workspace",
    "ngrok",
    "macos"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "4.19",
    "typescript": "5.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
