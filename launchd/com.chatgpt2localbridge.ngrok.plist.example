<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.chatgpt2localbridge.ngrok</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/ngrok</string>
    <string>http</string>
    <string>3838</string>
    <string>--url</string>
    <string>https://YOUR-FIXED-DOMAIN.ngrok-free.dev</string>
    <string>--log</string>
    <string>/Users/YOUR_USERNAME/.chatgpt2localbridge/logs/ngrok.log</string>
    <string>--log-format</string>
    <string>logfmt</string>
    <string>--log-level</string>
    <string>info</string>
    <string>--inspect=false</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USERNAME/.chatgpt2localbridge/logs/ngrok.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USERNAME/.chatgpt2localbridge/logs/ngrok.err.log</string>
</dict>
</plist>
